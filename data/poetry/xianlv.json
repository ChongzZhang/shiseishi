      "source": "全唐诗/poet.song.188000.json#226",
      "matchTier": 1,
      "verified": true,
      "dynasty": "宋"
    },
    {
      "line": "烟梢矗矗青围屋，露叶鲜鲜绿满篱。",
      "title": "题查山林氏庵",
      "author": "范成大",
      "type": "诗",
